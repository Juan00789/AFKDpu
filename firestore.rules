rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- GENERAL READ RULE ---
    // All documents are publicly readable. This fixes the "Publicidad Sana" loading issue.
    match /{document=**} {
      allow read: if true;
    }

    // --- SPECIFIC WRITE RULES ---

    // Users can only write to their own document.
    match /users/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Participants can write to a connection and its subcollections (like messages).
    match /connections/{connectionId}/{subcollection=**} {
      allow write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.userIds;
    }

    // Logged-in users can create reviews.
    match /reviews/{reviewId} {
      allow create: if request.auth != null;
      allow update, delete: if false; // Reviews are immutable
    }

    // Only the admin or the assigned provider can edit business data.
    match /businesses/{businessId} {
      allow write: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == 'alcantara00789@gmail.com' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.claimedBusinessId == businessId);
    }
  }
}
