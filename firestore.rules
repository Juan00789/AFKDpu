rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Reglas para la colección de usuarios
    match /users/{userId} {
      // Un usuario puede crear, leer y actualizar su propio documento de perfil.
      allow read, update, create: if request.auth != null && request.auth.uid == userId;
      
      // Cualquier usuario autenticado puede leer el perfil de otro usuario.
      // Esto es necesario para que los clientes puedan ver y seleccionar proveedores.
      allow get: if request.auth != null;
    }

    // Reglas para la colección de conexiones
    match /connections/{connectionId} {
      // Cualquier usuario autenticado puede crear una nueva conexión.
      allow create: if request.auth != null;
      
      // Solo los participantes de una conexión pueden leerla o actualizarla.
      allow read, update: if request.auth != null && request.auth.uid in resource.data.userIds;
    }

    // Reglas para los mensajes dentro de una conexión
    match /connections/{connectionId}/messages/{messageId} {
      // Solo los participantes de una conexión pueden leer o crear mensajes en ella.
      allow read, create: if request.auth != null && get(/databases/$(database)/documents/connections/$(connectionId)).data.userIds.hasAny([request.auth.uid]);
    }
  }
}
