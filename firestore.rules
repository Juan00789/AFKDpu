
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Solo el usuario autenticado puede leer o escribir su propio perfil.
      allow read, write: if request.auth.uid == userId;
    }

    match /connections/{connectionId} {
      // Un usuario puede crear una conexión si su UID está en la lista de participantes.
      allow create: if request.auth.uid in request.resource.data.userIds;
      // Solo los participantes de la conexión pueden leerla, actualizarla o eliminarla.
      allow read, update, delete: if request.auth.uid in resource.data.userIds;
    }
  }
}
