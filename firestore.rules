
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can be read by anyone (for profiles, provider lists),
    // but can only be written to by the authenticated user themselves.
    match /users/{userId} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Connections can be created, read, and updated only by users
    // who are participants in that connection.
    match /connections/{connectionId} {
      allow create: if request.auth != null && request.auth.uid in request.resource.data.userIds;
      allow read, update: if request.auth != null && request.auth.uid in resource.data.userIds;

      // Messages within a connection can only be created and read
      // by the participants of that parent connection.
      match /messages/{messageId} {
        allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.userIds;
      }
    }
  }
}
