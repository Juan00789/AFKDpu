rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read and write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Services can be created by authenticated users who are part of the service's userIds.
    // Services can be read only by the users who are participants in that service.
    match /services/{serviceId} {
      allow create: if request.auth != null && request.auth.uid in request.resource.data.userIds;
      allow read: if request.auth != null && resource.data.userIds.hasAny([request.auth.uid]);
    }
  }
}
