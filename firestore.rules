rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own profile, and other users can read a limited public version.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }
    
    // Users can read connections they are a part of.
    // They can create connections.
    // They can update connections they are a part of.
    match /connections/{connectionId} {
      allow read, update: if request.auth.uid in resource.data.userIds;
      allow create: if request.auth.uid != null;
    }
    
    // Users can read/write messages in connections they are a part of.
    match /connections/{connectionId}/messages/{messageId} {
      allow read, write: if request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.userIds;
    }

    // Allow logged-in users to create reviews.
    // Allow anyone to read reviews.
    match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth != null;
    }

    // Allow anyone to read business info for the public page.
    // Allow writes only if the user's claimedBusinessId matches the document ID.
    match /businesses/{businessId} {
        allow read: if true;
        allow write: if request.auth.uid != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.claimedBusinessId == businessId;
    }
  }
}
