rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /connections/{connectionId} {
      // A user can read or update a connection if they are a participant.
      allow read, update: if request.auth != null && resource.data.userIds.hasAny([request.auth.uid]);
      
      // A user can create a connection if they are listed as a participant in the new connection.
      allow create: if request.auth != null && request.resource.data.userIds.hasAny([request.auth.uid]);
    }
  }
}
