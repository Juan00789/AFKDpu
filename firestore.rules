
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Businesses collection: Public read, only authorized users can write.
    match /businesses/{businessId} {
      allow read: if true; // Anyone can read business info for the public page
      allow write: if request.auth != null && (
                    request.auth.token.email == 'alcantara00789@gmail.com' ||
                    (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.claimedBusinessId != null && 
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.claimedBusinessId == businessId)
                  );
    }

    // Users can be read publicly (for profiles), but only write to their own data.
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Reviews can be read by anyone, but only created by authenticated users.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false; // Reviews are immutable
    }
    
    // Connections and messages are private between participants.
    match /connections/{connectionId} {
      allow read, update: if request.auth != null && request.auth.uid in resource.data.userIds;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.creatorId;

      match /messages/{messageId} {
        allow read, create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.userIds;
      }
    }
  }
}
