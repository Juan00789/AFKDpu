rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Businesses: Public read, restricted write
    match /businesses/{businessId} {
      allow get: if true; // Allow anyone to read business data for public pages
      allow list: if true; // Allow listing if needed
      
      // Allow write only for admin or the user assigned to the business
      allow write: if request.auth != null && 
                   (request.auth.token.email == 'alcantara00789@gmail.com' ||
                    (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.claimedBusinessId == businessId));
    }
    
    // Users: Read by any authenticated user, write only by self
    match /users/{userId} {
      allow get: if request.auth != null;
      allow list: if request.auth != null;
      allow update: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
    }
    
    // Connections: Read/Write only by participants
    match /connections/{connectionId} {
      allow read, update, delete: if request.auth != null && request.auth.uid in resource.data.userIds;
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;

      // Messages subcollection
      match /messages/{messageId} {
        allow read, create: if request.auth != null && 
                             exists(/databases/$(database)/documents/connections/$(connectionId)) &&
                             request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.userIds;
      }
    }

    // Reviews: Public read, create only for authenticated users
    match /reviews/{reviewId} {
      allow get: if true; // Publicly readable
      allow list: if true; // Publicly readable
      allow create: if request.auth != null && request.resource.data.reviewerId == request.auth.uid;
    }
  }
}