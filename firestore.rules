rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles
    // - Anyone authenticated can read any user's profile information.
    // - A user can only create, update, or delete their OWN profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Connections (the chat sessions)
    // - An authenticated user can create a connection.
    // - Only participants of a connection can read or update it.
    match /connections/{connectionId} {
      allow create: if request.auth.uid != null;
      allow read, update: if request.auth.uid in resource.data.userIds;
    }

    // Messages within a connection
    // - Only participants can read messages or create new ones.
    match /connections/{connectionId}/messages/{messageId} {
      allow read, create: if request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.userIds;
    }
  }
}
