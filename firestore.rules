rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Rule for the 'businesses' collection to be publicly readable
    match /businesses/{businessId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default rule for all other collections
    // Allows any authenticated user to read/write anywhere.
    // This is for development and should be secured before production.
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
