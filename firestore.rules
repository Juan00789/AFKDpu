
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can read any profile, but only create or update their own.
    match /users/{userId} {
      allow read;
      allow create, update: if request.auth.uid == userId;
    }
    
    // Connections can be created by a participant.
    // They can be read or updated only by participants.
    match /connections/{connectionId} {
      allow read, update: if request.auth.uid in resource.data.userIds;
      allow create: if request.auth.uid in request.resource.data.userIds;
    }
    
    // Messages can be read or created only by participants of the parent connection.
    match /connections/{connectionId}/messages/{messageId} {
      allow read, create: if get(/databases/$(database)/documents/connections/$(connectionId)).data.userIds.hasAny([request.auth.uid]);
    }
  }
}
