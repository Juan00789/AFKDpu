rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // PUBLIC READ: Allow anyone to read business data for the public page.
    match /businesses/{businessId} {
      allow read: if true;
    }

    // AUTHENTICATED ACCESS: Allow any authenticated user full access to other collections.
    // This is for development purposes and should be secured before production.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
