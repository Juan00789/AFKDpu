rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read any profile, but only write to their own.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Participants can read/write connections they are a part of.
    match /connections/{connectionId} {
      // Create is allowed if the creator is in the participants list.
      // Read/Update/Delete is allowed if the user is in the participants list.
      allow read, write: if request.auth != null && resource.data.userIds.hasAny([request.auth.uid]);
    }

    // Participants can read/create messages in connections they are a part of.
    match /connections/{connectionId}/messages/{messageId} {
        allow read, create: if request.auth != null && get(/databases/$(database)/documents/connections/$(connectionId)).data.userIds.hasAny([request.auth.uid]);
        // Updates and deletes of messages are not allowed.
        allow update, delete: if false;
    }
  }
}