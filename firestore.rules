rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: These rules are permissive and are intended for development/prototyping.
    // They allow any authenticated user to read and write all data.
    // For a production app, you should implement more granular security rules.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}