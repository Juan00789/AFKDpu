[debug] [2025-07-07T21:39:08.195Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // Helper function to check if user is an admin\n    function isAdmin() {\n      return request.auth.token.email == 'alcantara00789@gmail.com';\n    }\n\n    // Helper function to check if a user is a participant in a connection\n    function isParticipant(connectionId) {\n      return request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.userIds;\n    }\n\n    // Users can be read by anyone, but only the user themselves or an admin can write.\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow update: if request.auth.uid == userId || isAdmin();\n      // Allow point updates from reviews\n      allow write: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points']);\n    }\n\n    // Connections can only be read/written by participants or admins.\n    match /connections/{connectionId} {\n      allow read, update, delete: if isParticipant(connectionId) || isAdmin();\n      allow create: if request.auth != null;\n    }\n\n    // Messages can only be read/written by participants of the parent connection.\n    match /connections/{connectionId}/messages/{messageId} {\n      allow read, create: if isParticipant(connectionId);\n      allow update, delete: if false; // Messages are immutable\n    }\n\n    // Reviews can be created by any authenticated user. They are immutable once created.\n    match /reviews/{reviewId} {\n        allow read: if true;\n        allow create: if request.auth != null;\n        allow update, delete: if false;\n    }\n    \n    // Business data can be read by anyone, but only written by an admin or the claimed user.\n    match /businesses/{businessId} {\n        allow read: if true;\n        allow write: if isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.claimedBusinessId == businessId;\n    }\n  }\n}\n"}]}}
