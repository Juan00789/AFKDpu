[debug] [2025-07-07T21:35:26.664Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isAdmin() {\n      return request.auth.token.email == 'alcantara00789@gmail.com';\n    }\n\n    // Users: Can read any profile, update their own. Points can be incremented by others.\n    match /users/{userId} {\n      allow read: if request.auth != null;\n\n      // Allow a user to update their own profile.\n      // Allow admin to make any change.\n      // Allow any authenticated user to increment points (for reviews).\n      // WARNING: This is permissive for a prototype. For production, point updates\n      // should ideally be handled by a server-side function for better security.\n      allow update: if request.auth.uid == userId || isAdmin() ||\n                       (request.auth.uid != null &&\n                        request.resource.data.points > resource.data.points &&\n                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points']));\n      \n      allow create: if request.auth.uid == userId;\n      allow delete: if false;\n    }\n\n    // Connections: Can be read/updated only by participants.\n    match /connections/{connectionId} {\n      allow read, update: if request.auth.uid in resource.data.userIds;\n      allow create: if request.resource.data.creatorId == request.auth.uid;\n      allow delete: if false;\n\n      // Messages: Can be read/created only by participants of the parent connection.\n      match /messages/{messageId} {\n        allow read: if request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.userIds;\n        allow create: if request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.userIds &&\n                         request.resource.data.senderId == request.auth.uid;\n        allow update, delete: if false;\n      }\n    }\n\n    // Reviews: Can be read by any authenticated user, but only created by the reviewer.\n    match /reviews/{reviewId} {\n      allow read: if request.auth != null;\n      allow create: if request.auth.uid == request.resource.data.reviewerId;\n      allow update, delete: if false;\n    }\n\n    // Businesses: Publicly readable, but only writable by admin or assigned provider.\n    match /businesses/{businessId} {\n        allow read: if true;\n        allow write: if isAdmin() ||\n                       (request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&\n                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.claimedBusinessId == businessId);\n    }\n  }\n}\n"}]}}
