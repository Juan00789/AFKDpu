[debug] [2025-07-07T21:52:30.450Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-app:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"\nrules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isAdmin() {\n      return request.auth.token.email == 'alcantara00789@gmail.com';\n    }\n\n    function isOwner(userId) {\n      return request.auth.uid == userId;\n    }\n\n    function isParticipant(connectionId) {\n      return request.auth.uid in get(/databases/$(database)/documents/connections/$(connectionId)).data.userIds;\n    }\n\n    match /users/{userId} {\n      allow read: if true;\n      allow create: if isOwner(userId);\n      allow update: if isOwner(userId) || \n                      (request.resource.data.points == resource.data.points + 1 ||\n                       request.resource.data.points == resource.data.points + 2 ||\n                       request.resource.data.points == resource.data.points + 3 ||\n                       request.resource.data.points == resource.data.points + 4 ||\n                       request.resource.data.points == resource.data.points + 5 ||\n                       request.resource.data.points == resource.data.points + 7 ||\n                       request.resource.data.points == resource.data.points + 10);\n    }\n\n    match /connections/{connectionId} {\n      allow read, update: if isParticipant(connectionId);\n      allow create: if request.auth.uid != null;\n    }\n\n    match /connections/{connectionId}/messages/{messageId} {\n      allow read, create: if isParticipant(connectionId);\n    }\n\n    match /reviews/{reviewId} {\n      allow read: if true;\n      allow create: if request.auth.uid != null;\n    }\n    \n    match /businesses/{businessId} {\n      allow read: if true;\n      allow update, create: if isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.claimedBusinessId == businessId;\n    }\n  }\n}\n"}]}}
