rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Todas las imágenes (avatares, productos) son de lectura pública.
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // Solo un usuario autenticado puede subir un avatar a su propia carpeta.
    match /avatars/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Solo un usuario autenticado puede subir imágenes de productos.
    // La lógica más fina (ser admin o dueño) se controla en la app.
    match /business_products/{businessId}/{fileName} {
      allow write: if request.auth != null;
    }
  }
}
