
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read access for all files.
    // Write access is restricted.
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // Users can only write to their own avatar folder.
    match /avatars/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Only authorized users can write to business product image folders.
    match /business_products/{businessId}/{fileName} {
       allow write: if request.auth != null && (
                    request.auth.token.email == 'alcantara00789@gmail.com' ||
                    (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.claimedBusinessId != null &&
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.claimedBusinessId == businessId)
                  );
    }
  }
}
