// REGLAS PARA STORAGE
// Pega este código en la sección de Reglas de "Storage" en tu consola de Firebase.
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // WARNING: These rules are permissive and are intended for development/prototyping.
    // They allow any authenticated user to read and write all files.
    // For a production app, you should implement more granular security rules.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
