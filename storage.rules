
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // PUBLIC READ for all images
    match /{allPaths=**} {
      allow read: if true;
    }

    // Authenticated users can write to their own avatar directory
    match /avatars/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Authenticated and assigned users can upload product images
    match /business_products/{businessId}/{fileName} {
      allow write: if request.auth != null && (request.auth.token.email == "alcantara00789@gmail.com" || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.claimedBusinessId == businessId));
    }
  }
}
