rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Avatar Images
    // - Anyone can view avatar images.
    // - An authenticated user can only upload/change/delete their OWN avatar.
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
    }
  }
}
