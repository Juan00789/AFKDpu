
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Business product images are public to read, but write is restricted.
    match /business_products/{businessId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // User avatars are public to read.
    // Only the authenticated user can upload/update their own avatar.
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
