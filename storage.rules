rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // --- GENERAL READ RULE ---
    // All files are publicly readable.
    match /{allPaths=**} {
      allow read: if true;
    }

    // --- SPECIFIC WRITE RULES ---

    // Users can only write to their own avatar folder.
    match /avatars/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Only the admin or assigned provider can upload product images.
    match /business_products/{businessId}/{fileName} {
      allow write: if request.auth != null && (get(/databases/(default)/documents/users/$(request.auth.uid)).data.email == 'alcantara00789@gmail.com' || get(/databases/(default)/documents/users/$(request.auth.uid)).data.claimedBusinessId == businessId);
    }
  }
}
