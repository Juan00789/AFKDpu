
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read files.
    // In a production app, you might want more restrictive read access.
    match /{allPaths=**} {
      allow read: if true;
    }

    // Allow users to write to their own avatar directory.
    match /avatars/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to upload product images.
    // A more secure rule would verify the user is the assigned owner of the business.
    match /business_products/{businessId}/{fileName} {
       allow write: if request.auth != null;
    }
  }
}
