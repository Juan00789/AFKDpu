
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /business_products/{businessId}/{allPaths=**} {
       allow read: if true;
       allow write: if request.auth != null && (get(/databases/(default)/documents/users/$(request.auth.uid)).data.email == 'alcantara00789@gmail.com' || get(/databases/(default)/documents/users/$(request.auth.uid)).data.claimedBusinessId == businessId);
    }
  }
}
