
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files, needed for avatars.
    match /{allPaths=**} {
      allow read;
    }
    // Allow write only to a user's own avatar folder.
    match /avatars/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
