rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Avatars: Publicly readable, but only the owner can write.
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Business Products: Publicly readable. Writable by authenticated users.
    // WARNING: For production, you should restrict write access further,
    // likely using a Cloud Function or custom claims, as Storage Rules cannot
    // directly check complex Firestore conditions like "is this user an admin?".
    // For this prototype, we allow any authenticated user assigned to the business to write.
    // The client-side code already restricts who can see the upload button.
    match /business_products/{businessId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
