rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
  
    // Avatars can be written only by the user themselves. Public read.
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Business product images can be written by the admin or the assigned provider. Public read.
    match /business_products/{businessId}/{fileName} {
       allow read: if true;
       allow write: if request.auth != null &&
        (request.auth.token.email == 'alcantara00789@gmail.com' ||
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.claimedBusinessId == businessId);
    }
  }
}
