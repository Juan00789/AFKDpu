rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files, so anyone can see avatars.
    match /{allPaths=**} {
      allow read;
    }
    
    // Users can only write to their own avatar directory.
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
